{
  "name": "CUNY Refiner",
  "description": "Simplify the CUNY interface and add useful features.",
  "version": "26.30.3",
  "manifest_version": 3,
  "permissions": [
    "contextMenus",
    "storage"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inst.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://globalsearch.cuny.edu/*",
        "*://cssa.cunyfirst.cuny.edu/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}